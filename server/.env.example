# Hermes Server Environment Variables
# Copy to .env and fill in your values

# =============================================================================
# AI BACKEND (OpenAI-compatible API)
# Supports: Hermes, Ollama, LM Studio, vLLM, OpenAI, DeepSeek, etc.
# Set AI_URL to your AI server address
# =============================================================================
AI_URL=http://127.0.0.1:11434
AI_KEY=your-api-key-here
AI_MODEL=llama3
AI_SYSTEM_PROMPT=You are a helpful assistant.

# Legacy Hermes config (optional - uses AI_URL if not set)
# HERMES_API_URL=http://127.0.0.1:8642
# HERMES_API_KEY=your-hermes-api-key

# Auth token for client connections
API_TOKEN=your-secure-random-token-here

# Server binding
LISTEN_HOST=0.0.0.0
LISTEN_PORT=5000
GATEWAY_PORT=5002

# Voice pipeline (optional - uses defaults if not set)
# WHISPER_CLI=/path/to/tool
# WHISPER_MODEL=/path/to/tool
# PIPER_VOICE=your-piper-voice
# PIPER_MODEL_DIR=/path/to/tool
